{
    "files.exclude": {
        "**/*.csproj.user": true,
        "**/*.userprefs": true,
        "**/packages": true,
        "**/*.tar.xz": true,
        "**/obj": true,
    },
    "omnisharp.projectLoadTimeout": 360,
    "editor.minimap.enabled": false,
    "explorer.openEditors.visible": 1,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
}   